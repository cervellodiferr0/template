{
  "_name": "Google Calendar MCP",
  "_description": "Read/write eventi Calendar. Schedule meeting auto.",
  "_setup_required": [
    "Cliente abilita Calendar API",
    "OAuth client ID + scopes calendar.events",
    "Salva credentials in 1Password"
  ],
  "config": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-gcal"],
    "env": {
      "GOOGLE_CALENDAR_CREDENTIALS": "${GCAL_CREDENTIALS}"
    }
  }
}
